<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="DevCache.UI.Views.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:DevCache.UI.Views"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:controls="using:CommunityToolkit.WinUI.UI.Controls" 
    xmlns:converters="using:CommunityToolkit.WinUI.Converters"
    mc:Ignorable="d">

    <Page.Resources>
        <converters:BoolToObjectConverter x:Key="NullToVisibilityConverter"
                                      TrueValue="Visible"
                                      FalseValue="Collapsed" />

        <!-- Inverts bool: true → false, false → true -->
        <converters:BoolNegationConverter x:Key="BoolNegationConverter" />

        <!-- bool true → Visible, false → Collapsed -->
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />

        <!-- Optional: smaller compact style for toolbar -->
        <x:Double x:Key="CommandBarCompactHeight">36</x:Double>
    </Page.Resources>

    <Grid >
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- Modern CommandBar toolbar -->
        <StackPanel Orientation="Horizontal"            
                    BorderThickness="0,0,0,1"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}">
            <!--Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"-->

            <AppBarButton Icon="Refresh"
                  Label="Refresh"
                  Command="{x:Bind ViewModel.RefreshCommand}"
                  IsEnabled="{x:Bind ViewModel.IsBusy, Mode=OneWay, Converter={StaticResource BoolNegationConverter}}"/>

            <AppBarSeparator/>

            <AppBarButton x:Name="FlushAllButton" 
                  Icon="Remove"
                  Label="Flush All"
                  Click="FlushAllButton_Click"/>

            <AppBarButton x:Name="DeleteKeyButton"
                  Icon="Delete" 
                  Label="Delete Key"
                  Click="DeleteKeyButton_Click"
                  IsEnabled="{x:Bind ViewModel.HasSelectedEntry, Mode=OneWay}"/>

            <AppBarSeparator />
            <AppBarButton
                  Icon="Edit" 
                  Label="Add Key"
                  Command="{x:Bind ViewModel.AddKeyCommand}"/>

            <AppBarButton x:Name="ExpireKeyButton" 
                  Icon="Clock" 
                  Label="Set Expiry"
                  Click="ExpireKeyButton_Click"
                  IsEnabled="{x:Bind ViewModel.HasSelectedEntry, Mode=OneWay}"/>

        </StackPanel>

        <TeachingTip
            x:Name="FlushAllTeachingTip"
            Title="Flush entire database?"                
            ActionButtonContent="Flush All"
            ActionButtonCommand="{x:Bind ViewModel.FlushDbCommand}"
            ActionButtonStyle="{StaticResource AccentButtonStyle}"
            ActionButtonClick="FlushAllTeachingTip_ActionButtonClick"
            CloseButtonContent="Cancel"
            IsLightDismissEnabled="False"
            PlacementMargin="20"
            Target="{x:Bind FlushAllButton}">
            <TeachingTip.IconSource>
                <SymbolIconSource Symbol="Delete"/>
            </TeachingTip.IconSource>
            <TeachingTip.Content>
                <StackPanel Spacing="12" Margin="0,15" >
                    <TextBlock Text="This action cannot be undone." 
                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                </StackPanel>
            </TeachingTip.Content>
        </TeachingTip>

        <TeachingTip
            x:Name="DeleteKeyTeachingTip"
            Title="Delete selected key?"                
            ActionButtonContent="Delete"
            ActionButtonStyle="{StaticResource AccentButtonStyle}"
            ActionButtonCommand="{x:Bind ViewModel.DeleteSelectedCommand}"
            ActionButtonClick="DeleteKeyTeachingTip_ActionButtonClick"
            CloseButtonContent="Cancel"
            IsLightDismissEnabled="False"
            PlacementMargin="20"
            Target="{x:Bind DeleteKeyButton}">
            <TeachingTip.IconSource>
                <SymbolIconSource Symbol="Delete"/>
            </TeachingTip.IconSource>
            <TeachingTip.Content>
                <StackPanel Spacing="12" Margin="0,15" >
                    <TextBlock Text="This action cannot be undone." TextWrapping="Wrap" />
                    <TextBlock Text="{x:Bind ViewModel.SelectedEntry.Key, Mode=OneWay, FallbackValue='Selected key'}"
                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                </StackPanel>
            </TeachingTip.Content>
        </TeachingTip>

        <TeachingTip
            x:Name="SetKeyTeachingTip"
            Title="Set New / Update"
            ActionButtonContent="Save"
            ActionButtonCommand="{x:Bind ViewModel.SetKeyConfirmCommand}"
            ActionButtonClick="SetKeyTeachingTip_ActionButtonClick"
            CloseButtonContent="Close"
            IsLightDismissEnabled="False"
            PlacementMargin="20" >
            <TeachingTip.IconSource>
                <SymbolIconSource Symbol="Add" />
            </TeachingTip.IconSource>
            <TeachingTip.Content>
                <StackPanel Spacing="12" Margin="0,15" MinWidth="320">
                    <TextBlock Text="Key" FontWeight="SemiBold"/>
                    <TextBox Text="{x:Bind ViewModel.KeyText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                 PlaceholderText="Enter key name"/>

                    <TextBlock Text="Value" FontWeight="SemiBold" Margin="0,8,0,0"/>
                    <TextBox Text="{x:Bind ViewModel.ValueText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                 PlaceholderText="Enter value"
                 AcceptsReturn="True"
                 Height="100"
                 TextWrapping="Wrap"/>
                </StackPanel>
            </TeachingTip.Content>
        </TeachingTip>

        <TeachingTip 
            x:Name="ExpireKeyTeachingTip"
            Title="Set Expiration"
            ActionButtonContent="Apply Expire"
            ActionButtonCommand="{x:Bind ViewModel.ExpireKeyConfirmCommand}"
            ActionButtonClick="ExpireKeyTeachingTip_ActionButtonClick"
            CloseButtonContent="Cancel"
            IsLightDismissEnabled="False"
            PlacementMargin="20"
            Target="{x:Bind ExpireKeyButton}"
            Closed="ExpireKeyTeachingTip_Closed">
            <TeachingTip.IconSource>
                <SymbolIconSource Symbol="Clock" />
            </TeachingTip.IconSource>
            <TeachingTip.Content>
                <StackPanel Spacing="12" Margin="0,15">
                    <TextBlock Text="Selected Key:" FontWeight="SemiBold" />
                    <TextBlock Text="{x:Bind ViewModel.SelectedEntry.Key, Mode=OneWay, FallbackValue='(none)'}" 
                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />

                    <TextBlock Text="Expire in (seconds):" FontWeight="SemiBold" Margin="0,12,0,0" />
                    <NumberBox 
                         x:Name="ExpireSecondsInput"
                         Value="{x:Bind ViewModel.ExpireSeconds, Mode=TwoWay}"
                         Minimum="1"
                         Maximum="31536000"     
                         PlaceholderText="e.g. 3600 (1 hour)"
                         SpinButtonPlacementMode="Inline" />

                    <TextBlock Text="Current TTL:" FontWeight="SemiBold" Margin="0,8,0,0"                                      
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    <!--Visibility="{x:Bind ViewModel.SelectedEntry.TtlSeconds > 0, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"-->
                    <TextBlock Text="{x:Bind ViewModel.SelectedEntry.TtlSeconds, Mode=OneWay, FallbackValue='No expiration'}"                        
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    <!--Visibility="{x:Bind ViewModel.SelectedEntry.TtlSeconds > 0, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"-->
                </StackPanel>
            </TeachingTip.Content>
        </TeachingTip>

        <SplitView 
            Grid.Row="1"
            x:Name="MainSplitView"
            DisplayMode="Inline"
            PanePlacement="Right"
            IsPaneOpen="{x:Bind ViewModel.IsPaneOpen, Mode=OneWay}"
            OpenPaneLength="420"
            CompactPaneLength="0"
            Background="Transparent">

            <!-- Left side: Toolbar + Key List -->
            <SplitView.Content>
                    <!-- Data Grid -->
                    <controls:DataGrid x:Name="KeyGrid"
                       ItemsSource="{x:Bind ViewModel.Entries, Mode=OneWay}"
                       SelectedItem="{x:Bind ViewModel.SelectedEntry, Mode=TwoWay}"
                       AutoGenerateColumns="False"
                       IsReadOnly="True"
                       DoubleTapped="KeyGrid_DoubleTapped"
                       BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                       BorderThickness="1"
                       CornerRadius="{ThemeResource OverlayCornerRadius}">

                        <controls:DataGrid.Columns>
                            <controls:DataGridTextColumn Header="Key" 
                                         Binding="{Binding Key}" 
                                         Width="*"/>
                            <controls:DataGridTextColumn Header="Type" 
                                         Binding="{Binding Type}" 
                                         Width="100"/>
                            <controls:DataGridTextColumn Header="TTL (s)" 
                                         Binding="{Binding TtlSeconds}" 
                                         Width="90"/>
                            <controls:DataGridTextColumn Header="Size (B)" 
                                         Binding="{Binding SizeBytes}" 
                                         Width="90"/>
                        </controls:DataGrid.Columns>

                    </controls:DataGrid>

                <!--<TeachingTip
                        x:Name="ShowKeyTeachingTip"
                        Title="View Key"    
                        PreferredPlacement="Top"
                        Target="{x:Bind StatusGrid}">
                    <TeachingTip.IconSource>
                        <SymbolIconSource Symbol="View" />
                    </TeachingTip.IconSource>
                    <TeachingTip.Content>
                        <StackPanel Spacing="8" Margin="0,15">
                            <TextBlock Text="Selected Key:" FontWeight="SemiBold" />
                            <TextBlock Text="{x:Bind ViewModel.SelectedEntry.Key, Mode=OneWay}" />
                            <TextBlock Text="Value:" FontWeight="SemiBold" Margin="0,8,0,0" />
                            <TextBox Text="{x:Bind ViewModel.SelectedEntry.Value, Mode=OneWay}" 
                         IsReadOnly="True" 
                         TextWrapping="Wrap" 
                         Height="120" />
                        </StackPanel>
                    </TeachingTip.Content>
                </TeachingTip>-->
            </SplitView.Content>
            <!-- Right side: Edit / View Pane -->
            <SplitView.Pane>
                <Grid BorderThickness="1,0,0,0"
                      Background="{ThemeResource AccentAcrylicBackgroundFillColorDefaultBrush}"
                      BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                      Padding="15,10">
                    <!--Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"-->

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Header -->
                    <Grid ColumnSpacing="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        
                        <FontIcon 
                            Grid.Column="0" 
                            Glyph="&#xE8F4;" 
                            FontSize="24"
                            VerticalAlignment="Center"/>

                        <!-- View/Edit icon -->
                        <TextBlock 
                            Grid.Column="1" 
                            Text="Key Details" 
                            VerticalAlignment="Center"
                            Style="{StaticResource SubtitleTextBlockStyle}"/>

                        <Button 
                            Grid.Column="2"
                            Style="{StaticResource AlternateCloseButtonStyle}"
                            VerticalAlignment="Center"
                            Command="{x:Bind ViewModel.ClosePaneCommand}"/>
                    </Grid>

                    <!-- Edit form - only visible when selected -->
                    <ScrollViewer 
                        Grid.Row="1"
                        Margin="0,10">

                        <StackPanel Spacing="16">

                            <StackPanel>
                                <TextBox 
                                    Header="Key"
                                    Text="{x:Bind ViewModel.KeyText, Mode=TwoWay}"
                                    Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"/>
                            </StackPanel>

                            <StackPanel>
                                <TextBox 
                                    Header="Value"
                                    Text="{x:Bind ViewModel.ValueText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                    AcceptsReturn="True"
                                    Height="160"
                                    TextWrapping="Wrap"
                                    PlaceholderText="Enter or edit value here"/>
                            </StackPanel>

                            <StackPanel Visibility="{x:Bind ViewModel.IsExpiryMode, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                                <NumberBox 
                                    Header="Set Expiration (seconds)"
                                    Value="{x:Bind ViewModel.ExpireSeconds, Mode=TwoWay}"
                                    Minimum="0"
                                    Maximum="31536000"
                                    PlaceholderText="0 = no expiration"
                                    SpinButtonPlacementMode="Inline"/>
                            </StackPanel>

                            <!-- Current TTL / Size info -->
                            <StackPanel 
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                BorderThickness="0.5" 
                                Orientation="Horizontal" 
                                Spacing="30" 
                                Margin="0,8,0,0"
                                Padding="8">
                                <StackPanel Spacing="5">
                                    <TextBlock Text="Type" FontWeight="SemiBold" FontSize="12"/>
                                    <TextBlock Text="{x:Bind ViewModel.SelectedEntry.Type, Mode=OneWay, FallbackValue='∞'}"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                </StackPanel>
                                <StackPanel Spacing="5">
                                    <TextBlock Text="Current TTL" FontWeight="SemiBold" FontSize="12"/>
                                    <TextBlock Text="{x:Bind ViewModel.SelectedEntry.TtlSeconds, Mode=OneWay, FallbackValue='∞'}"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                </StackPanel>
                                <StackPanel Spacing="5">
                                    <TextBlock Text="Size" FontWeight="SemiBold" FontSize="12"/>
                                    <TextBlock Text="{x:Bind ViewModel.SelectedEntry.SizeBytes, Mode=OneWay, FallbackValue='?'}"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>
                    </ScrollViewer>

                    <!-- Action buttons at bottom -->
                    <StackPanel Grid.Row="2"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Spacing="12"
                        Margin="0,16,0,0"
                        Visibility="{x:Bind ViewModel.IsNewOrEditMode, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">

                        <Button Content="Delete Key"
                        Command="{x:Bind ViewModel.DeleteSelectedCommand}"
                        />
                        <!-- red accent if you have it -->

                        <Button Content="Save Changes"
                        Command="{x:Bind ViewModel.SetKeyConfirmCommand}"
                        Style="{StaticResource AccentButtonStyle}"/>

                        <Button Content="Close" Click="ClosePane_Click"/>
                    </StackPanel>
                </Grid>
            </SplitView.Pane>

            <VisualStateManager.VisualStateGroups>
                <VisualStateGroup x:Name="WindowStates">
                    <VisualState x:Name="WideState">
                        <VisualState.StateTriggers>
                            <AdaptiveTrigger MinWindowWidth="900"/>
                        </VisualState.StateTriggers>
                        <VisualState.Setters>
                            <Setter Target="MainSplitView.DisplayMode" Value="Inline"/>
                            <Setter Target="MainSplitView.IsPaneOpen" Value="True"/>
                            <!-- always open on wide -->
                        </VisualState.Setters>
                    </VisualState>
                    <VisualState x:Name="NarrowState">
                        <VisualState.StateTriggers>
                            <AdaptiveTrigger MinWindowWidth="0"/>
                        </VisualState.StateTriggers>
                        <VisualState.Setters>
                            <Setter Target="MainSplitView.DisplayMode" Value="Overlay"/>
                            <!-- IsPaneOpen controlled by selection -->
                        </VisualState.Setters>
                    </VisualState>
                </VisualStateGroup>
            </VisualStateManager.VisualStateGroups>

        </SplitView>

        <!-- Bottom status row -->
        <Grid 
            x:Name="StatusGrid"
            Grid.Row="2"              
            BorderThickness="0,1,0,0"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            Padding="12,8">
            <!--Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"-->
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <ProgressBar 
                IsIndeterminate="{x:Bind ViewModel.IsBusy, Mode=OneWay}"
                Width="140"
                Visibility="{x:Bind ViewModel.IsBusy, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"/>

            <TextBlock 
                Grid.Column="1"
                Text="{x:Bind ViewModel.Status, Mode=OneWay}"
                VerticalAlignment="Center"
                Margin="16,0,0,0"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
        </Grid>
    </Grid>
    
</Page>
